{
  "name": "@rura/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"const {spawnSync}=require('child_process'); const result=spawnSync('next',['build'],{stdio:'inherit',shell:true,env:{...process.env,NEXT_TELEMETRY_DISABLED:'1'}}); process.exit(result.status ?? 1);\"",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vis.gl/react-google-maps": "^1.8.3",
    "gsap": "^3.12.5",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
